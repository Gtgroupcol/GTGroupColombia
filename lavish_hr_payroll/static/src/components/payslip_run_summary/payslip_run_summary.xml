<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="lavish_hr_payroll.PayslipRunSummary">
        <div class="payslip_run_summary prn-summary-container">
            <!-- Loading -->
            <div t-if="state.loading" class="text-center p-5">
                <i class="fa fa-spinner fa-spin fa-3x prn-loading-spinner"></i>
                <p class="mt-3 prn-loading-text">Cargando nóminas...</p>
            </div>

            <div t-else="" class="w-100" role="region" aria-label="Resumen de nómina">
                <!-- Barra de herramientas -->
                <div class="mb-3 p-3 rounded prn-toolbar">
                    <!-- Fila 1: Filtros -->
                    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <!-- Filtro departamento -->
                            <select class="form-select form-select-sm prn-select-department" t-on-change="onDepartmentChange" aria-label="Filtrar por departamento">
                                <option value="all">Todos los departamentos</option>
                                <t t-foreach="state.departments" t-as="dept" t-key="dept">
                                    <option t-att-value="dept" t-att-selected="state.selectedDepartment === dept"><t t-esc="dept"/></option>
                                </t>
                            </select>
                            <!-- Búsqueda -->
                            <div class="input-group input-group-sm prn-search-group">
                                <span class="input-group-text prn-search-addon"><i class="fa fa-search prn-search-icon"></i></span>
                                <input type="text" class="form-control prn-toolbar-input" placeholder="Buscar empleado..." t-on-input="onSearchInput" aria-label="Buscar empleado por nombre o cédula"/>
                            </div>
                        </div>
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <!-- Items por página -->
                            <div class="d-flex align-items-center gap-1">
                                <span class="small text-muted">Mostrar:</span>
                                <select class="form-select form-select-sm prn-select-page-size" t-on-change="onPageSizeChange" aria-label="Cantidad de nóminas por página">
                                    <option value="5" t-att-selected="state.pageSize === 5">5</option>
                                    <option value="10" t-att-selected="state.pageSize === 10">10</option>
                                    <option value="20" t-att-selected="state.pageSize === 20">20</option>
                                    <option value="50" t-att-selected="state.pageSize === 50">50</option>
                                </select>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <button class="btn prn-toolbar-btn" t-on-click="expandAll" title="Expandir todos" aria-label="Expandir todas las nóminas">
                                    <i class="fa fa-expand"></i>
                                </button>
                                <button class="btn prn-toolbar-btn" t-on-click="collapseAll" title="Colapsar todos" aria-label="Colapsar todas las nóminas">
                                    <i class="fa fa-compress"></i>
                                </button>
                                <button class="btn prn-toolbar-btn-primary" t-on-click="refreshData" title="Actualizar datos" aria-label="Actualizar datos de nóminas">
                                    <i class="fa fa-refresh"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Fila 2: Resumen y paginación -->
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="badge px-3 py-2 prn-badge-count">
                                <i class="fa fa-users me-1"></i> <t t-esc="filteredPayslips.length"/> de <t t-esc="state.payslips.length"/> nóminas
                            </span>
                            <span class="px-2 py-1 rounded prn-badge-devengos">
                                <i class="fa fa-plus-circle me-1"></i>Dev: <strong><t t-esc="formatCurrency(filteredTotals.earnings)"/></strong>
                            </span>
                            <span class="px-2 py-1 rounded prn-badge-deducciones">
                                <i class="fa fa-minus-circle me-1"></i>Ded: <strong><t t-esc="formatCurrency(filteredTotals.deductions)"/></strong>
                            </span>
                            <span class="px-2 py-1 rounded prn-badge-neto">
                                <i class="fa fa-money me-1"></i>Neto: <strong><t t-esc="formatCurrency(filteredTotals.net)"/></strong>
                            </span>
                        </div>
                        <!-- Paginación -->
                        <div class="d-flex align-items-center gap-2" t-if="totalPages > 1">
                            <button class="btn btn-sm prn-toolbar-btn" t-on-click="prevPage" t-att-disabled="state.currentPage === 1" aria-label="Página anterior">
                                <i class="fa fa-chevron-left"></i>
                            </button>
                            <span class="small px-2 prn-pagination-text">Pág <strong><t t-esc="state.currentPage"/></strong> de <t t-esc="totalPages"/></span>
                            <button class="btn btn-sm prn-toolbar-btn" t-on-click="nextPage" t-att-disabled="state.currentPage === totalPages" aria-label="Página siguiente">
                                <i class="fa fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Sin datos -->
                <div t-if="!hasData" class="text-center p-5 prn-no-data">
                    <i class="fa fa-inbox fa-4x mb-3"></i>
                    <p class="fs-5">No hay nóminas en este lote</p>
                </div>

                <!-- Lista de Nóminas -->
                <div t-else="" class="payslips-container w-100" role="list">
                    <t t-foreach="paginatedPayslips" t-as="payslip" t-key="payslip.id">
                        <div t-att-class="'card mb-3 shadow-sm prn-employee-card prn-state-' + payslip.state" role="listitem">
                            <!-- Header -->
                            <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center prn-employee-header"
                                 t-on-click="() => this.togglePayslip(payslip.id)"
                                 t-att-aria-label="'Expandir detalle de ' + payslip.employee_name">
                                <div class="d-flex align-items-center gap-3">
                                    <i t-att-class="'fa fa-lg prn-chevron ' + (isPayslipExpanded(payslip.id) ? 'fa-chevron-down' : 'fa-chevron-right')"></i>
                                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold prn-avatar">
                                        <t t-esc="payslip.employee_name.substring(0,2).toUpperCase()"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold fs-6 prn-employee-name"><t t-esc="payslip.employee_name"/></div>
                                        <small class="prn-employee-detail">
                                            <i class="fa fa-id-card-o me-1"></i><t t-esc="payslip.identification"/>
                                            <span class="mx-2">|</span>
                                            <i class="fa fa-building-o me-1"></i><t t-esc="payslip.department"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-4">
                                    <div class="text-end">
                                        <div class="small mb-1">
                                            <span class="prn-amount-devengo"><i class="fa fa-arrow-up me-1"></i><t t-esc="formatCurrency(payslip.gross)"/></span>
                                            <span class="prn-amount-separator mx-2">-</span>
                                            <span class="prn-amount-deduccion"><i class="fa fa-arrow-down me-1"></i><t t-esc="formatCurrency(payslip.deductions)"/></span>
                                        </div>
                                        <div class="fw-bold fs-5 prn-amount-neto"><t t-esc="formatCurrency(payslip.net)"/></div>
                                    </div>
                                    <span t-att-class="'badge px-3 py-2 prn-badge-state-' + payslip.state"
                                          t-att-aria-label="'Estado: ' + getStateBadge(payslip.state).text">
                                        <t t-esc="getStateBadge(payslip.state).text"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Contenido expandido -->
                            <div t-if="isPayslipExpanded(payslip.id)" class="card-body p-0">
                                <!-- Barra de acciones -->
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 flex-wrap gap-2 prn-action-bar">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn prn-action-btn" t-on-click.stop="() => this.openPayslipModal(payslip.id, payslip.employee_name)" title="Ver nómina">
                                            <i class="fa fa-eye me-1"></i> Ver
                                        </button>
                                        <button class="btn prn-action-btn-compute" t-on-click.stop="() => this.computePayslip(payslip.id)" title="Recalcular nómina">
                                            <i class="fa fa-calculator me-1"></i> Computar
                                        </button>
                                        <button class="btn prn-action-btn" t-on-click.stop="() => this.openPayslipForm(payslip.id)" title="Abrir formulario completo">
                                            <i class="fa fa-external-link me-1"></i> Abrir
                                        </button>
                                    </div>
                                    <!-- Opciones de novedades -->
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button class="btn btn-sm prn-action-btn-novelty" t-on-click.stop="() => this.addNoveltyToEmployee(payslip.employee_id, payslip.employee_name)" title="Agregar novedad/concepto">
                                            <i class="fa fa-plus me-1"></i> Novedad
                                        </button>
                                        <button class="btn btn-sm prn-action-btn-overtime" t-on-click.stop="() => this.addOvertimeToEmployee(payslip.employee_id, payslip.employee_name)" title="Agregar hora extra">
                                            <i class="fa fa-clock-o me-1"></i> H. Extra
                                        </button>
                                        <button class="btn btn-sm prn-action-btn-leave" t-on-click.stop="() => this.addLeaveToEmployee(payslip.employee_id, payslip.employee_name)" title="Agregar ausencia">
                                            <i class="fa fa-calendar-minus-o me-1"></i> Ausencia
                                        </button>
                                        <button class="btn btn-sm prn-action-btn-loan" t-on-click.stop="() => this.addLoanToEmployee(payslip.employee_id, payslip.employee_name)" title="Agregar préstamo">
                                            <i class="fa fa-money me-1"></i> Préstamo
                                        </button>
                                        <button class="btn btn-sm prn-action-btn-list" t-on-click.stop="() => this.viewEmployeeNovelties(payslip.employee_id, payslip.employee_name)" title="Ver todas las novedades" t-if="payslip.novelty_count > 0">
                                            <i class="fa fa-list"></i> (<t t-esc="payslip.novelty_count"/>)
                                        </button>
                                    </div>
                                </div>

                                <!-- Tabla de líneas -->
                                <div class="row g-0 prn-expanded-min-height">
                                    <!-- DEVENGOS -->
                                    <div class="col-6 prn-col-divider">
                                        <div class="p-3">
                                            <div class="d-flex align-items-center mb-3 pb-2 prn-devengos-header">
                                                <i class="fa fa-plus-circle fa-lg me-2 prn-icon-earnings"></i>
                                                <h3 class="fw-bold prn-devengos-title">DEVENGOS</h3>
                                            </div>

                                            <!-- Salario Básico -->
                                            <t t-if="payslip.basic_lines and payslip.basic_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-briefcase me-2 prn-icon-basic"></i>
                                                        <span class="fw-bold small prn-section-label">Salario Básico</span>
                                                    </div>
                                                    <t t-foreach="payslip.basic_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-basic'"/>
                                                            <t t-set="lineIcon" t-value="'fa-money'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Auxilio de Transporte -->
                                            <t t-if="payslip.transport_lines and payslip.transport_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-bus me-2 prn-icon-transport"></i>
                                                        <span class="fw-bold small prn-section-label">Auxilio Transporte</span>
                                                    </div>
                                                    <t t-foreach="payslip.transport_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-transport'"/>
                                                            <t t-set="lineIcon" t-value="'fa-bus'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Horas Extra -->
                                            <t t-if="payslip.overtime_lines and payslip.overtime_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-clock-o me-2 prn-icon-overtime"></i>
                                                        <span class="fw-bold small prn-section-label">Horas Extra y Recargos</span>
                                                        <span class="badge ms-2 prn-badge-overtime-count"><t t-esc="payslip.overtime_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.overtime_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-overtime'"/>
                                                            <t t-set="lineIcon" t-value="'fa-clock-o'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Ausencias/Vacaciones -->
                                            <t t-if="payslip.absence_lines and payslip.absence_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-calendar-check-o me-2 prn-icon-absence"></i>
                                                        <span class="fw-bold small prn-section-label">Vacaciones / Ausencias</span>
                                                        <span class="badge ms-2 prn-badge-absence-count"><t t-esc="payslip.absence_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.absence_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-absence'"/>
                                                            <t t-set="lineIcon" t-value="'fa-calendar'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Devengos No Salariales -->
                                            <t t-if="payslip.non_salary_earnings and payslip.non_salary_earnings.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-gift me-2 prn-icon-non-salary"></i>
                                                        <span class="fw-bold small prn-section-label">Devengos No Salariales</span>
                                                        <span class="badge ms-2 prn-badge-non-salary-count"><t t-esc="payslip.non_salary_earnings.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.non_salary_earnings" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-non-salary'"/>
                                                            <t t-set="lineIcon" t-value="'fa-gift'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- IBD/IBC del Período -->
                                            <t t-if="payslip.ibd_ibc_lines and payslip.ibd_ibc_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-database me-2 prn-icon-ibd"></i>
                                                        <span class="fw-bold small prn-section-label">IBD / IBC del Período</span>
                                                        <span class="badge ms-2 prn-badge-ibd-count"><t t-esc="payslip.ibd_ibc_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.ibd_ibc_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-ibd'"/>
                                                            <t t-set="lineIcon" t-value="'fa-database'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- IBC de Períodos Anteriores -->
                                            <t t-if="payslip.ibc_previous_lines and payslip.ibc_previous_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-history me-2 prn-icon-ibc-prev"></i>
                                                        <span class="fw-bold small prn-section-label">IBC Períodos Anteriores</span>
                                                        <span class="badge ms-2 prn-badge-ibc-prev-count"><t t-esc="payslip.ibc_previous_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.ibc_previous_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-ibc-prev'"/>
                                                            <t t-set="lineIcon" t-value="'fa-history'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Otros Devengos -->
                                            <t t-if="payslip.other_earnings and payslip.other_earnings.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-plus me-2 prn-icon-other-earn"></i>
                                                        <span class="fw-bold small prn-section-label">Otros Devengos</span>
                                                    </div>
                                                    <t t-foreach="payslip.other_earnings" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-other-earn'"/>
                                                            <t t-set="lineIcon" t-value="'fa-plus'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Total Devengos -->
                                            <div class="pt-2 mt-3 d-flex justify-content-between fw-bold prn-devengos-total">
                                                <span class="prn-devengos-total-text"><i class="fa fa-calculator me-2"></i>TOTAL DEVENGOS</span>
                                                <span class="prn-devengos-total-amount"><t t-esc="formatCurrency(payslip.gross)"/></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- DEDUCCIONES -->
                                    <div class="col-6">
                                        <div class="p-3">
                                            <div class="d-flex align-items-center mb-3 pb-2 prn-deducciones-header">
                                                <i class="fa fa-minus-circle fa-lg me-2 prn-icon-deductions"></i>
                                                <h3 class="fw-bold prn-deducciones-title">DEDUCCIONES</h3>
                                            </div>

                                            <!-- Salud -->
                                            <t t-if="payslip.health_lines and payslip.health_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-medkit me-2 prn-icon-health"></i>
                                                        <span class="fw-bold small prn-section-label">Salud (EPS)</span>
                                                    </div>
                                                    <t t-foreach="payslip.health_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-health'"/>
                                                            <t t-set="lineIcon" t-value="'fa-medkit'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Pensión -->
                                            <t t-if="payslip.pension_lines and payslip.pension_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-shield me-2 prn-icon-pension"></i>
                                                        <span class="fw-bold small prn-section-label">Pensión</span>
                                                    </div>
                                                    <t t-foreach="payslip.pension_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-pension'"/>
                                                            <t t-set="lineIcon" t-value="'fa-shield'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Fondo Solidaridad -->
                                            <t t-if="payslip.solidarity_lines and payslip.solidarity_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-handshake-o me-2 prn-icon-solidarity"></i>
                                                        <span class="fw-bold small prn-section-label">Fondo Solidaridad</span>
                                                    </div>
                                                    <t t-foreach="payslip.solidarity_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-solidarity'"/>
                                                            <t t-set="lineIcon" t-value="'fa-handshake-o'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Retención en la Fuente -->
                                            <t t-if="payslip.retention_lines and payslip.retention_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-percent me-2 prn-icon-retention"></i>
                                                        <span class="fw-bold small prn-section-label">Retención Fuente</span>
                                                    </div>
                                                    <t t-foreach="payslip.retention_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-retention'"/>
                                                            <t t-set="lineIcon" t-value="'fa-percent'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Préstamos -->
                                            <t t-if="payslip.loan_lines and payslip.loan_lines.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-credit-card me-2 prn-icon-loans"></i>
                                                        <span class="fw-bold small prn-section-label">Préstamos</span>
                                                    </div>
                                                    <t t-foreach="payslip.loan_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-loans'"/>
                                                            <t t-set="lineIcon" t-value="'fa-credit-card'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Otras Deducciones -->
                                            <t t-if="payslip.other_deductions and payslip.other_deductions.length > 0">
                                                <div class="mb-3">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-minus me-2 prn-icon-other-ded"></i>
                                                        <span class="fw-bold small prn-section-label">Otras Deducciones</span>
                                                    </div>
                                                    <t t-foreach="payslip.other_deductions" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-other-ded'"/>
                                                            <t t-set="lineIcon" t-value="'fa-minus'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Total Deducciones -->
                                            <div class="pt-2 mt-3 d-flex justify-content-between fw-bold prn-deducciones-total">
                                                <span class="prn-deducciones-total-text"><i class="fa fa-calculator me-2"></i>TOTAL DEDUCCIONES</span>
                                                <span class="prn-deducciones-total-amount"><t t-esc="formatCurrency(payslip.deductions)"/></span>
                                            </div>

                                            <!-- Prestaciones Sociales -->
                                            <t t-if="payslip.benefits_lines and payslip.benefits_lines.length > 0">
                                                <div class="mt-3 pt-2 prn-benefits-border">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-trophy me-2 prn-icon-benefits"></i>
                                                        <h3 class="fw-bold small prn-benefits-title">Prestaciones Sociales</h3>
                                                        <span class="badge ms-2 prn-badge-benefits-count"><t t-esc="payslip.benefits_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.benefits_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-benefits'"/>
                                                            <t t-set="lineIcon" t-value="'fa-trophy'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>

                                            <!-- Provisiones -->
                                            <t t-if="payslip.provision_lines and payslip.provision_lines.length > 0">
                                                <div class="mt-3 pt-2 prn-provisions-border">
                                                    <div class="d-flex align-items-center mb-2 pb-1 prn-section-border-dashed">
                                                        <i class="fa fa-bank me-2 prn-icon-provisions"></i>
                                                        <h3 class="fw-bold small prn-provisions-title">Provisiones</h3>
                                                        <span class="badge ms-2 prn-badge-provisions-count"><t t-esc="payslip.provision_lines.length"/></span>
                                                    </div>
                                                    <t t-foreach="payslip.provision_lines" t-as="line" t-key="line.id">
                                                        <t t-call="lavish_hr_payroll.PayslipLineRow">
                                                            <t t-set="lineClass" t-value="'prn-line-color-provisions'"/>
                                                            <t t-set="lineIcon" t-value="'fa-bank'"/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <!-- Registros: Horas Extra y Ausencias -->
                                <div t-if="(payslip.overtime_records and payslip.overtime_records.length > 0) or (payslip.leave_records and payslip.leave_records.length > 0)"
                                     class="row g-0 prn-records-area">
                                    <div class="col-6 prn-col-divider">
                                        <div class="p-3" t-if="payslip.overtime_records and payslip.overtime_records.length > 0">
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="fa fa-clock-o me-2 prn-overtime-header-icon"></i>
                                                <span class="fw-bold small prn-overtime-header-text">Horas Extra Registradas (<t t-esc="payslip.overtime_count"/>)</span>
                                            </div>
                                            <t t-foreach="payslip.overtime_records" t-as="ot" t-key="ot.id">
                                                <div class="d-flex justify-content-between align-items-center py-1 px-2 mb-1 rounded prn-record-row">
                                                    <div>
                                                        <span class="prn-record-text"><t t-esc="ot.type"/></span>
                                                        <span class="ms-2 prn-record-date"><i class="fa fa-calendar me-1"></i><t t-esc="ot.date"/></span>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="badge prn-overtime-badge"><t t-esc="formatNumber(ot.hours)"/> hrs</span>
                                                        <i class="fa fa-info-circle prn-record-info-icon" t-on-click.stop="() => this.viewOvertime(ot.id)" title="Ver detalle"></i>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-3" t-if="payslip.leave_records and payslip.leave_records.length > 0">
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="fa fa-calendar-minus-o me-2 prn-leave-header-icon"></i>
                                                <span class="fw-bold small prn-leave-header-text">Ausencias Registradas (<t t-esc="payslip.leave_count"/>)</span>
                                            </div>
                                            <t t-foreach="payslip.leave_records" t-as="lv" t-key="lv.id">
                                                <div class="d-flex justify-content-between align-items-center py-1 px-2 mb-1 rounded prn-record-row">
                                                    <div>
                                                        <span class="prn-record-text"><t t-esc="lv.type"/></span>
                                                        <span class="ms-2 prn-record-date"><t t-esc="lv.date_from"/> - <t t-esc="lv.date_to"/></span>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="badge prn-leave-badge"><t t-esc="formatNumber(lv.days)"/> días</span>
                                                        <i class="fa fa-info-circle prn-record-info-icon" t-on-click.stop="() => this.viewLeave(lv.id)" title="Ver detalle"></i>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <!-- Novedades -->
                                <div t-if="payslip.novelties and payslip.novelties.length > 0" class="prn-novelties-area">
                                    <div class="p-3 prn-novelties-bg">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fa fa-bell me-2 prn-novelty-icon"></i>
                                            <span class="fw-bold small prn-novelty-title">Novedades Aplicadas (<t t-esc="payslip.novelties.length"/>)</span>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2">
                                            <t t-foreach="payslip.novelties" t-as="nov" t-key="nov.id">
                                                <span class="badge px-2 py-1 prn-novelty-badge">
                                                    <t t-esc="nov.concept"/> - <t t-esc="formatCurrency(nov.amount)"/>
                                                    <span t-if="nov.date" class="ms-1 prn-novelty-date">(<t t-esc="nov.date"/>)</span>
                                                </span>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <!-- NETO A PAGAR -->
                                <div class="p-3 d-flex justify-content-between align-items-center prn-net-footer">
                                    <h3 class="fw-bold fs-5 prn-net-footer-title"><i class="fa fa-money me-2"></i>NETO A PAGAR</h3>
                                    <span class="fs-3 fw-bold"><t t-esc="formatCurrency(payslip.net)"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

    <!-- Sub-template para lineas de nomina -->
    <t t-name="lavish_hr_payroll.PayslipLineRow">
        <div class="d-flex justify-content-between align-items-center py-1 px-2 mb-1 rounded prn-line-row"
             t-on-click.stop="() => this.viewPayslipLineDetail(line.id, line.name)"
             t-att-title="'Click para ver detalle de: ' + line.name">
            <div class="d-flex align-items-center prn-line-content">
                <span class="badge me-2 prn-line-id-badge">
                    <t t-esc="line.id"/>
                </span>
                <span class="text-truncate prn-line-name" t-att-title="line.name">
                    <span class="me-1 prn-line-code"><t t-esc="line.code"/></span>
                    <t t-esc="line.name"/>
                </span>
                <i t-if="line.rule_id" class="fa fa-info-circle ms-2 prn-line-info-icon"
                   t-on-click.stop="() => this.viewSalaryRule(line.rule_id, line.rule_name)"
                   title="Ver regla salarial"></i>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span t-if="line.category" class="badge prn-line-category-badge">
                    <t t-esc="line.category"/>
                </span>
                <span t-if="line.quantity and line.quantity != 1" class="badge prn-line-qty-badge">
                    <t t-esc="formatNumber(line.quantity)"/> x <t t-esc="formatNumber(line.rate)"/>%
                </span>
                <span t-att-class="'fw-bold ' + lineClass"><t t-esc="formatCurrency(Math.abs(line.total))"/></span>
                <i class="fa fa-external-link-square prn-line-external-icon" title="Ver detalle"></i>
            </div>
        </div>
    </t>

</templates>
