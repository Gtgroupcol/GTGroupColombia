<odoo>
    <data>
        <record model="ir.ui.view" id="view_customer_contract_diagnostic_tree">
            <field name="name">view_customer_contract_diagnostic_tree</field>
            <field name="model">customer.contract.diagnostic</field>
            <field name="arch" type="xml">
                <tree string="Ayudas Diagnosticas" editable="top">
                    <field name="active" />
                    <field name="code" />
                    <field name="name" />
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_customer_contract_diagnostic_form">
            <field name="name">view.customer.contract.diagnostic.form</field>
            <field name="model">customer.contract.diagnostic</field>
            <field name="arch" type="xml">
                <form string="Ayuda Diagnostica">
                    <sheet>
                        <group>
                            <field name="active" />
                            <field name="code" />
                            <field name="name" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_benefit_plan_form" model="ir.ui.view">
            <field name="name">benefit.plan.form</field>
            <field name="model">benefit.plan</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Nombre del Plan"/>
                            </h1>
                        </div>
                        <group>
                            <field name="code"/>
                            <field name="color"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_benefit_plan_tree" model="ir.ui.view">
            <field name="name">benefit.plan.tree</field>
            <field name="model">benefit.plan</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                </tree>
            </field>
        </record>

    </data>
</odoo>
