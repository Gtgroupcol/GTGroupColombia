        <record id="view_hr_payslip_edi_form_inherit" model="ir.ui.view">
            <field name="inherit_id" ref="epayroll.view_hr_payslip_edi_form"/>
            <field name="model">hr.payslip.edi</field>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='update_data']" position="after">
                    <button name="compute_sheet_nes" string="Compute Hoja Electronica" type="object"/>
                    <button name="validate" 
                            string="Validar DIAN" 
                            type="object"
                            invisible="state == 'draft' or state_dian == 'por_notificar'"/>
                    <button name="validate" 
                            string="Revisar status DIAN" 
                            type="object"
                            invisible="state == 'draft' or state_dian in ('por_notificar', 'exitoso')"/>
                    <button name="test_xml" 
                            string="Test XML" 
                            type="object" 
                            groups="base.group_no_one"/>
                    <button string="Refund"
                            name="refund_sheet"
                            type="object"
                            invisible="credit_note or state == 'draft' or state_dian != 'exitoso'"/>
                </xpath>
                
                <xpath expr="//field[@name='credit_note']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
                
                <xpath expr="//field[@name='payslip_run_id']" position="after">
                    <field name="payment_date" 
                        required="True" 
                        readonly="state == 'done'"/>
                </xpath>
                
                <xpath expr="//page[last()]" position="after">
                    <page string="Calculos Nomina Electronica">
                        <field name="nes_dev_line_ids" colspan="4" readonly="True">
                            <tree>
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="leave_id"/>
                                <field name="code" optional="hide"/>
                                <field name="departure_date" optional="hide"/>
                                <field name="return_date" optional="hide"/>
                                <field name="category_id" optional="hide"/>
                                <field name="quantity" optional="hide"/>
                                <field name="salary_rule_id" optional="hide"/>
                                <field name="amount" optional="hide"/>
                                <field name="total"/>
                                <field name="name_2"/>
                                <field name="code_2" optional="hide"/>
                                <field name="rate_2" optional="hide"/>
                                <field name="total_2"/>
                            </tree>
                        </field>
                        <field name="nes_ded_line_ids" colspan="4" readonly="True">
                            <tree>
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="code" optional="hide"/>
                                <field name="category_id" optional="hide"/>
                                <field name="quantity" optional="hide"/>
                                <field name="salary_rule_id" optional="hide"/>
                                <field name="amount" optional="hide"/>
                                <field name="total"/>
                                <field name="name_2"/>
                                <field name="code_2" optional="hide"/>
                                <field name="rate_2" optional="hide"/>
                                <field name="total_2"/>
        
                            </tree>
                        </field>
                    </page>
                    <page name="dian" string="DIAN">
                        <group>
                            <field name="state_dian"/>
                            <field name="refusal_reason"/>
                            <field name="response_message_dian"/>
                            <field name="xml_response_dian" 
                                invisible="state_dian == 'exitoso'"/>
                            <field name="current_cune" 
                                groups="base.group_no_one"/>
                            <field name="previous_cune" 
                                groups="base.group_no_one"
                                invisible="not credit_note"/>
                            <field name="type_note"
                                invisible="not credit_note"
                                required="credit_note"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>


        <record id="hr_payslip_tree_inherit" model="ir.ui.view">
            <field name="name">hr.payslip.inherit.tree</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_to']" position="after">
                    <field name="state_dian"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
