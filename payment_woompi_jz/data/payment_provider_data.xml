<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_method_wompicol" model="payment.method">
            <field name="name">Wompicol</field>
            <field name="code">wompicol</field>
            <field name="sequence">80</field>
            <field name="active">True</field>
            <field name="image" type="base64" file="payment_woompi_jz/static/description/icon.png"/>
            <field name="support_tokenization">False</field>
            <field name="support_express_checkout">False</field>

    </record>


    <record id="payment_provider_onvopay" model="payment.provider">
            <field name="name">Wompicol</field>
            <field name="code">wompicol</field>
            <field name="image_128" type="base64" file="payment_woompi_jz/static/description/icon.png"/>
            <field name="module_id" ref="base.module_payment_woompi_jz"/>
            <field name="payment_method_ids" eval="[(6, 0, [ref('payment_woompi_jz.payment_method_wompicol'),])]"/>

            <field name="redirect_form_view_id" ref="redirect_form"/>

            <field name="company_id" ref="base.main_company"/>
    </record>

</odoo>
