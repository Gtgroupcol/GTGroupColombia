<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_leave_allocation_view_form" model="ir.ui.view">
            <field name="name">hr.leave.allocation.form</field>
            <field name="model">hr.leave.allocation</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form"/>
            <field name="arch" type="xml">
                <field name="holiday_status_id" position='after'>
                    <field name="enfermedad_id" />
                </field>
            </field>
        </record>

    <record id="action_hr_gt_enfermedad" model="ir.actions.act_window">
        <field name="name">Enfermedades </field>
        <field name="res_model">hr.gt.enfermedad</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hr_gt_enfermedad" name="Enfermedades"
              parent="hr_holidays.menu_hr_holidays_configuration"
              action="action_hr_gt_enfermedad"/>


</odoo>