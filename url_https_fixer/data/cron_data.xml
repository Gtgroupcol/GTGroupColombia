<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Cron Job para verificar URL cada minuto -->
    <record id="cron_url_https_fixer" model="ir.cron">
        <field name="name">URL HTTPS Fixer - Verificar cada minuto</field>
        <field name="model_id" ref="model_url_https_fixer"/>
        <field name="state">code</field>
        <field name="code">model.fix_url_https()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
