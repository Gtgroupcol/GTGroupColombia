<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_country_tree" model="ir.ui.view">
            <field name="name">res.country.tree.lavish</field>
            <field name="model">res.country</field>
            <field name="inherit_id" ref="base.view_country_tree"/>
            <field name="arch" type="xml">
                <field name='code' position="after">
                    <field name="dian_code" optional="show"/>
                    <field name="numeric_code" optional="hide"/>
                    <field name="address_builder_enabled" optional="show"/>
                    <field name="neighborhood_enabled" optional="show"/>
                    <field name="zip_required" optional="show"/>
                </field>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_country_form" model="ir.ui.view">
            <field name="name">res.country.form.lavish</field>
            <field name="model">res.country</field>
            <field name="inherit_id" ref="base.view_country_form"/>
            <field name="arch" type="xml">
                <!-- Agregar campos DIAN -->
                <field name='code' position="after">
                    <field name="dian_code"/>
                    <field name="numeric_code"/>
                </field>

                <!-- Agregar seccion de configuracion de direcciones -->
                <xpath expr="//group" position="after">
                    <group string="Configuracion de Direcciones">
                        <group>
                            <field name="address_builder_enabled"/>
                            <field name="neighborhood_enabled"/>
                            <field name="zip_required"/>
                        </group>
                        <group>
                            <field name="state_required"/>
                        </group>
                    </group>

                    <!-- Notebook con ciudades y codigos postales -->
                    <notebook>
                        <page string="Ciudades" name="cities">
                            <field name="city_ids" mode="tree" context="{'default_country_id': id}">
                                <tree string="Ciudades" editable="bottom">
                                    <field name="name"/>
                                    <field name="state_id" domain="[('country_id', '=', parent.id)]"/>
                                    <field name="zipcode" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Codigos Postales" name="postal_codes">
                            <field name="postal_code_count" readonly="1"/>
                            <button name="action_view_postal_codes" type="object"
                                    string="Ver Codigos Postales" class="btn-link"
                                    icon="fa-external-link"/>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
