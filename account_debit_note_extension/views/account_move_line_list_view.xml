<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_move_line_tree_inherit_custom_button" model="ir.ui.view">
      <field name="name">account.move.line.tree.inherit.custom.button</field>
      <field name="model">account.move.line</field>
      <field name="inherit_id" ref="account.view_move_line_tree"/>
      <field name="arch" type="xml"> 
        <field name="amount_residual" position="after">
          <field name="reconciled" invisible="1"/>
        </field>
        <tree position="inside">
          <button name="action_reconcile_13_22" 
                  type="object"
                  string="Cruzar Cobros/Pagos"
                  icon="fa-exchange"
                  invisible="reconciled or amount_residual == 0"/>
        </tree>
      </field>
    </record>
  </data>
</odoo>