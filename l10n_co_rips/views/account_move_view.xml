<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="invoice_tree_extended_fe" model="ir.ui.view">
            <field name="name">documento DIAN de una factura</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="generate_pdf_zip"
                        string="Descargar PDFs"
                        type="object"
                        class="btn-primary" />
                </xpath>

            </field>
        </record>
        <record id="view_move_form_inherit_rips" model="ir.ui.view">
            <field name="name">account.move.form.inherit.rips</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <!-- Botones en el header -->
                <xpath expr="//header" position="inside">
                    <button name="action_send_rips_to_minsalud"
                        type="object"
                        string="Enviar RIPS al MinSalud"
                        class="btn-primary"
                        invisible="move_type not in ['out_invoice', 'out_refund', 'in_refund'] and fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte'] or rips_validation_status == 'validated'"
                        confirm="¿Está seguro de enviar este RIPS al Ministerio de Salud?"
                        groups="account.group_account_invoice" />

                    <button name="action_retry_rips_validation"
                        type="object"
                        string="Reintentar Envío"
                        class="btn-warning"
                        invisible="rips_validation_status not in ['rejected', 'error']"
                        groups="account.group_account_invoice" />

                    <button name="action_consult_cuv"
                        type="object"
                        string="Consultar CUV"
                        class="btn-info"
                        invisible="not rips_cuv"
                        groups="account.group_account_invoice" />

                    <button name="action_validate_cups_codes"
                        type="object"
                        string="Validar CUPS"
                        class="btn-warning"
                        invisible="rips_validated_cups or move_type not in ['out_invoice', 'out_refund']"
                        groups="account.group_account_invoice" />
                </xpath>

                <!-- Badge de estado junto al título -->
                <xpath expr="//div[hasclass('oe_title')]" position="before">
                    <div class="d-flex justify-content-between mb-2 oe_avatar">
                        <div class="d-flex align-items-center">
                            <!-- Estado DIAN -->
                            <div class="d-flex align-items-center me-3" invisible="not cufe">
                                <span class="fa fa-shield fa-2x me-2"
                                    style="color: #28a745;"
                                    invisible="state_dian_document != 'exitoso'" />
                                <span class="fa fa-shield fa-2x me-2"
                                    style="color: #dc3545;"
                                    invisible="state_dian_document not in ['error', 'rechazado']" />
                                <span class="fa fa-shield fa-2x me-2"
                                    style="color: #6c757d;"
                                    invisible="state_dian_document in ['exitoso', 'error', 'rechazado']" />
                                <div>
                                    <small class="text-muted">DIAN</small>
                                    <br />
                                    <field name="state_dian_document" widget="badge" nolabel="1"
                                        decoration-success="state_dian_document == 'exitoso'"
                                        decoration-danger="state_dian_document in ['error', 'rechazado']"
                                        decoration-info="state_dian_document in ['por_notificar','por_validar']" />
                                </div>
                            </div>
                            <!-- Estado RIPS -->
                            <div class="d-flex align-items-center" invisible="not rips_generated">
                                <span class="fa fa-file-text-o fa-2x me-2"
                                    style="color: #28a745;"
                                    invisible="rips_validation_status != 'validated'" />
                                <span class="fa fa-file-text-o fa-2x me-2"
                                    style="color: #dc3545;"
                                    invisible="rips_validation_status not in ['rejected', 'error']" />
                                <span class="fa fa-file-text-o fa-2x me-2"
                                    style="color: #ffc107;"
                                    invisible="rips_validation_status not in ['sent', 'generated']" />
                                <span class="fa fa-file-text-o fa-2x me-2"
                                    style="color: #6c757d;"
                                    invisible="rips_validation_status not in ['draft']" />
                                <div>
                                    <small class="text-muted">RIPS</small>
                                    <br />
                                    <field name="rips_validation_status" widget="badge" nolabel="1"
                                        decoration-success="rips_validation_status == 'validated'"
                                        decoration-danger="rips_validation_status in ['rejected', 'error']"
                                        decoration-warning="rips_validation_status == 'sent'"
                                        decoration-info="rips_validation_status in ['draft', 'generated']" />
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>

                <!-- Campos invisibles necesarios -->
                <xpath expr="//sheet" position="inside">
                    <field name="rips_generated" invisible="1" />
                    <field name="is_adjustment_note" invisible="1" />
                    <field name="is_voluntary_agreement" invisible="1" />
                    <field name="is_total_credit_note" invisible="1" />
                    <field name="rips_without_invoice" invisible="1" />
                    <field name="rips_proceso_id" invisible="1" />
                    <field name="rips_json" invisible="1" />
                    <field name="rips_json_binary" invisible="1" />
                    <field name="rips_json_filename" invisible="1" />
                    <field name="rips_consultation_history" invisible="1" />
                    <field name="rips_response_json" invisible="1" />
                    <field name="rips_errors" invisible="1" />
                    <field name="capita_type" invisible="1" />
                    <field name="rips_result_binary" invisible="1" />
                    <field name="rips_result_filename" invisible="1" />
                    <field name="rips_errors_html_binary" invisible="1" />
                    <field name="rips_errors_html_filename" invisible="1" />
                    <field name="rips_errors_html" invisible="1" />
                    <field name="rips_cuv" invisible="1" />
                    <field name="rips_validation_date" invisible="1" />
                    <field name="rips_last_load_type" invisible="1" />
                    <field name="attached_document_xml" invisible="1" />
                    <field name="attached_document_xml_filename" invisible="1" />
                    <field name="rips_validated_cups" invisible="1" />
                    <field name="rips_validation_cups_date" invisible="1" />
                    <field name="rips_validation_cups_result" invisible="1" />
                    <field name="is_in_rips_export" invisible="1" />
                    <field name="ripsjson_id" invisible="1" />
                    <field name="health_prepaid_amount" invisible="1" />
                    <field name="cufe" invisible="1" />
                    <field name="state_dian_document" invisible="1" />
                </xpath>

                <!-- Campos del paciente en el encabezado -->
                <xpath expr="//group[@name='sale_info_group']" position="after">
                    <group string="Información del Paciente" name="patient_info_group"
                        invisible="move_type not in ['out_invoice', 'out_refund']">
                        <group>
                            <field name="patient_id"
                                context="{'default_is_patient': True}"
                                options="{'no_create': True}" />
                            <field name="header_patient_doc_type" />
                            <field name="header_patient_document" />
                            <field name="header_patient_name" />
                        </group>
                        <group>
                            <field name="header_patient_birth_date" />
                            <field name="header_patient_gender" />
                            <field name="header_patient_user_type" />
                            <field name="authorization_number" />
                        </group>
                    </group>

                    <group string="Localización del Paciente" name="patient_location_group"
                        invisible="move_type not in ['out_invoice', 'out_refund'] or not patient_id">
                        <group>
                            <field name="header_patient_country_id" />
                            <field name="header_patient_city_id"
                                domain="[('country_id', '=', header_patient_country_id)]" />
                        </group>
                        <group>
                            <field name="header_patient_zone" />
                            <field name="header_patient_nationality" />
                        </group>
                    </group>
                </xpath>

                <!-- Agregar campo del sector salud visible al inicio -->
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="is_health_sector"
                        widget="boolean_toggle"
                        invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']" />
                </xpath>


                <!-- Agregar campos de recaudo después del tipo de operación -->
                <xpath expr="//group[@id='header_right_group']" position="after">
                    <group string="Campos de salud" col="2"
                        invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']">
                        <field name="patient_id"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']"
                            required="is_health_sector == True" />
                        <field name="contract_id"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']"
                            domain="[('partner_id', '=', partner_id)]" />
                        <field name="health_collection_concept_id"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']"
                            string="Concepto de Recaudo" />
                        <field name="health_payment_mode_id"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']"
                            string="Modalidad de Pago" />
                        <field name="health_coverage_plan_id"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']"
                            string="Tipo de Cobertura" />
                        <field name="authorization_number" />
                        <field name="date_start" />
                        <field name="date_end" />
                    </group>
                </xpath>
                <xpath expr="//field[@name='line_ids']/tree/field[@name='account_id']"
                    position="after">
                    <field name="patient_id" optional="hide" string="Paciente" />
                    <field name="patient_doc_type" optional="hide" string="Tipo Doc" />
                    <field name="patient_document" optional="hide" string="Documento" />
                    <field name="patient_name" optional="hide" string="Nombre Paciente" />
                    <field name="patient_birth_date" optional="hide" string="F. Nacimiento" />
                    <field name="patient_gender" optional="hide" string="Género" />
                    <field name="patient_user_type" optional="hide" string="Tipo Usuario" />
                    <field name="patient_city_id" optional="hide" string="Ciudad" />
                    <field name="patient_country_id" optional="hide" string="País" />
                    <field name="patient_zone" optional="hide" string="Zona" />
                    <field name="patient_nationality" optional="hide" string="Nacionalidad" />

                    <!-- Campos de servicio -->
                    <field name="treatment_id" optional="hide" string="Tratamiento" />
                    <field name="autorizacion" optional="hide" string="Autorización" />
                    <field name="id_mipres" optional="hide" string="ID MIPRES" />
                    <field name="professional_id" optional="hide" string="Profesional" />

                    <!-- Fechas -->
                    <field name="fecha_atencion" optional="hide" string="F. Atención" />
                    <field name="fecha_procedimiento" optional="hide" string="F. Procedimiento" />
                    <field name="fecha_dispensacion" optional="hide" string="F. Dispensación" />
                    <field name="fecha_suministro" optional="hide" string="F. Suministro" />

                    <!-- Campos de pago moderador -->
                    <field name="tipo_pago_moderador" optional="hide" string="Tipo Pago Mod." />
                    <field name="valor_pago_moderador" optional="hide" string="Valor Pago Mod." />
                    <field name="num_fev_pago_moderador" optional="hide" string="FEV Pago Mod." />

                    <!-- Campos para consultas -->
                    <field name="modalidad" optional="hide" string="Modalidad" />
                    <field name="grupo_servicio" optional="hide" string="Grupo Servicio" />
                    <field name="cod_servicio" optional="hide" string="Cód. Servicio" />
                    <field name="finalidad" optional="hide" string="Finalidad" />
                    <field name="causa_externa" optional="hide" string="Causa Externa" />
                    <field name="diagnostico_principal" optional="hide" string="Diag. Principal" />
                    <field name="diagnostico_relacionado1" optional="hide" string="Diag. Rel. 1" />
                    <field name="diagnostico_relacionado2" optional="hide" string="Diag. Rel. 2" />
                    <field name="diagnostico_relacionado3" optional="hide" string="Diag. Rel. 3" />
                    <field name="tipo_diagnostico" optional="hide" string="Tipo Diag." />

                    <!-- Campos para procedimientos -->
                    <field name="via_ingreso" optional="hide" string="Vía Ingreso" />
                    <field name="diagnostico_relacionado" optional="hide" string="Diag. Relacionado" />
                    <field name="complicacion" optional="hide" string="Complicación" />

                    <!-- Campos para medicamentos -->
                    <field name="tipo_medicamento" optional="hide" string="Tipo Med." />
                    <field name="concentracion" optional="hide" string="Concentración" />
                    <field name="unidad_medida" optional="hide" string="Unidad Medida" />
                    <field name="forma_farmaceutica" optional="hide" string="Forma Farm." />
                    <field name="unidad_min_dispensacion" optional="hide" string="Unidad Min." />
                    <field name="dias_tratamiento" optional="hide" string="Días Trat." />

                    <!-- Campos para otros servicios -->
                    <field name="tipo_servicio" optional="hide" string="Tipo Servicio" />
                </xpath>
                <!-- Campos en líneas de factura -->
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='product_id']"
                    position="after">
                    <field name="patient_id" optional="hide" string="Paciente" />
                    <field name="patient_doc_type" optional="hide" string="Tipo Doc" />
                    <field name="patient_document" optional="hide" string="Documento" />
                    <field name="patient_name" optional="hide" string="Nombre Paciente" />
                    <field name="patient_birth_date" optional="hide" string="F. Nacimiento" />
                    <field name="patient_gender" optional="hide" string="Género" />
                    <field name="patient_user_type" optional="hide" string="Tipo Usuario" />
                    <field name="patient_city_id" optional="hide" string="Ciudad" />
                    <field name="patient_country_id" optional="hide" string="País" />
                    <field name="patient_zone" optional="hide" string="Zona" />
                    <field name="patient_nationality" optional="hide" string="Nacionalidad" />

                    <!-- Campos de servicio -->
                    <field name="treatment_id" optional="hide" string="Tratamiento" />
                    <field name="autorizacion" optional="hide" string="Autorización" />
                    <field name="id_mipres" optional="hide" string="ID MIPRES" />
                    <field name="professional_id" optional="hide" string="Profesional" />

                    <!-- Fechas -->
                    <field name="fecha_atencion" optional="hide" string="F. Atención" />
                    <field name="fecha_procedimiento" optional="hide" string="F. Procedimiento" />
                    <field name="fecha_dispensacion" optional="hide" string="F. Dispensación" />
                    <field name="fecha_suministro" optional="hide" string="F. Suministro" />

                    <!-- Campos de pago moderador -->
                    <field name="tipo_pago_moderador" optional="hide" string="Tipo Pago Mod." />
                    <field name="valor_pago_moderador" optional="hide" string="Valor Pago Mod." />
                    <field name="num_fev_pago_moderador" optional="hide" string="FEV Pago Mod." />

                    <!-- Campos para consultas -->
                    <field name="modalidad" optional="hide" string="Modalidad" />
                    <field name="grupo_servicio" optional="hide" string="Grupo Servicio" />
                    <field name="cod_servicio" optional="hide" string="Cód. Servicio" />
                    <field name="finalidad" optional="hide" string="Finalidad" />
                    <field name="causa_externa" optional="hide" string="Causa Externa" />
                    <field name="diagnostico_principal" optional="hide" string="Diag. Principal" />
                    <field name="diagnostico_relacionado1" optional="hide" string="Diag. Rel. 1" />
                    <field name="diagnostico_relacionado2" optional="hide" string="Diag. Rel. 2" />
                    <field name="diagnostico_relacionado3" optional="hide" string="Diag. Rel. 3" />
                    <field name="tipo_diagnostico" optional="hide" string="Tipo Diag." />

                    <!-- Campos para procedimientos -->
                    <field name="via_ingreso" optional="hide" string="Vía Ingreso" />
                    <field name="diagnostico_relacionado" optional="hide" string="Diag. Relacionado" />
                    <field name="complicacion" optional="hide" string="Complicación" />

                    <!-- Campos para medicamentos -->
                    <field name="tipo_medicamento" optional="hide" string="Tipo Med." />
                    <field name="concentracion" optional="hide" string="Concentración" />
                    <field name="unidad_medida" optional="hide" string="Unidad Medida" />
                    <field name="forma_farmaceutica" optional="hide" string="Forma Farm." />
                    <field name="unidad_min_dispensacion" optional="hide" string="Unidad Min." />
                    <field name="dias_tratamiento" optional="hide" string="Días Trat." />

                    <!-- Campos para otros servicios -->
                    <field name="tipo_servicio" optional="hide" string="Tipo Servicio" />
                </xpath>

                <!-- Pestañas adicionales -->
                <xpath expr="//notebook" position="inside">
               <page string="Datos de Salud" name="health_data"
                        invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']">
                        <group>
                            <group string="Información del Paciente">
                                <field name="header_patient_doc_type" />
                                <field name="header_patient_document" />
                                <field name="header_patient_name" />
                                <field name="header_patient_birth_date" />
                                <field name="header_patient_gender" />
                                <field name="header_patient_user_type" />
                            </group>
                            <group string="Información Adicional">
                                <field name="physician_id" />
                                <field name="department_id" />
                                <field name="diagnosis_id" />
                                <field name="authorization_number" />
                                <field name="date_start" />
                                <field name="date_end" />
                                <field name="invoice_type" />
                            </group>
                        </group>

                        <group string="Localización del Paciente">
                            <group>
                                <field name="header_patient_country_id" />
                                <field name="header_patient_city_id"
                                    domain="[('country_id', '=', header_patient_country_id)]" />
                                <field name="header_patient_zone" />
                                <field name="header_patient_nationality" />
                            </group>
                        </group>

                        <group string="Prepagos del Sector Salud"
                            invisible="fe_operation_type not in ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte']">
                            <group>
                                <field name="copay_amount" widget="monetary" />
                                <field name="moderator_fee_amount" widget="monetary" />
                                <field name="shared_payment_amount" widget="monetary" />
                                <field name="recovery_fee_amount" widget="monetary" />
                            </group>
                           
                        </group>
                    </page>

                    <page string="Anticipos y Prepagos" name="prepaid_payments">
                        <group string="Prepagos del Sector Salud">
                            <group>
                                <field name="copay_amount" widget="monetary" />
                                <field name="moderator_fee_amount" widget="monetary" />
                                <field name="shared_payment_amount" widget="monetary" />
                                <field name="recovery_fee_amount" widget="monetary" />
                            </group>
                            <group>
                                <field name="health_prepaid_amount" widget="monetary" readonly="1"
                                    string="Total Prepagos"
                                    help="Suma total de prepagos del sector salud" />

                            </group>
                        </group>

                        <separator string="Referencias de Prepago" />
                        <field name="health_prepaid_references"
                            context="{'default_invoice_id': id, 'default_partner_id': partner_id}">
                            <tree string="Referencias de Prepago">
                                <field name="collection_concept_code" required="1" />
                                <field name="amount" widget="monetary" sum="Total" required="1" />
                                <field name="currency_id" column_invisible="1" />
                                <field name="received_date" required="1" />
                                <field name="paid_date" />
                                <field name="invoice_reference" required="1" />
                                <field name="reference_invoice_id"
                                    domain="[('partner_id', '=', parent.partner_id), ('state', '=', 'posted')]"
                                    options="{'no_create': True}" />
                                <field name="description" />
                                <field name="is_applied" readonly="1" widget="boolean_toggle" />
                            </tree>
                            <form string="Referencia de Prepago">
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="collection_concept_code" />
                                            <field name="amount" widget="monetary" />
                                            <field name="currency_id" invisible="1" />
                                        </group>
                                        <group>
                                            <field name="received_date" />
                                            <field name="paid_date" />
                                            <field name="invoice_reference" />
                                            <field name="reference_invoice_id" />
                                        </group>
                                    </group>
                                    <group>
                                        <field name="description"
                                            placeholder="Descripción adicional..." />
                                    </group>
                                    <group string="Información de Aplicación"
                                        invisible="not is_applied">
                                        <field name="is_applied" readonly="1" />
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>

                    <!-- Pestaña RIPS -->
                    <page string="RIPS" name="rips_info"
                        invisible="move_type not in ['out_invoice', 'out_refund', 'in_refund']">
                        <group col="4" string="Información RIPS">
                            <!-- Columna izquierda: Estado y datos -->
                            <group colspan="2" string="Estado de Validación">
                                <field name="rips_validation_status" string="Estado" widget="badge"
                                    readonly="1" />
                                <field name="rips_cuv" string="CUV" invisible="not rips_cuv"
                                    readonly="1" widget="copy_clipboard" />
                                <field name="rips_proceso_id" string="ID Proceso"
                                    invisible="not rips_proceso_id" readonly="1" />
                                <field name="rips_validation_date" string="Fecha Validación"
                                    invisible="not rips_validation_date" readonly="1" />
                                <field name="rips_last_load_type" string="Tipo de Carga"
                                    invisible="not rips_last_load_type" readonly="1" />
                            </group>

                            <!-- Mensaje informativo cuando no hay RIPS generado -->
                            <div invisible="rips_generated" colspan="4"
                                style="text-align: center; padding: 40px; background-color: #f8f9fa; border-radius: 8px; margin: 20px 0;">
                                <i class="fa fa-file-text-o"
                                    style="font-size: 48px; color: #6c757d; margin-bottom: 16px;" />
                                <h4 style="color: #495057; margin-bottom: 8px;">No hay RIPS generado</h4>
                                <p style="color: #6c757d; margin: 0;"> Haga clic en <strong>"Enviar
                                    RIPS al MinSalud"</strong> para generar y enviar automáticamente
                                    el archivo RIPS. </p>
                            </div>

                            <!-- Columna derecha: Botones de descarga -->
                            <group colspan="2" string="Archivos Disponibles"
                                invisible="not rips_generated">
                                <div style="display: flex; flex-direction: column; gap: 10px;">
                                    <button name="action_view_rips_json"
                                        type="object"
                                        string="Descargar JSON RIPS"
                                        class="btn-secondary btn-sm"
                                        icon="fa-file-code-o"
                                        style="text-align: left;" />

                                    <button name="action_download_result_file"
                                        type="object"
                                        string="Descargar Resultado TXT"
                                        class="btn-secondary btn-sm"
                                        icon="fa-file-text-o"
                                        invisible="not rips_result_binary"
                                        style="text-align: left;" />

                                    <button name="action_view_rips_errors_html"
                                        type="object"
                                        string="Descargar Reporte HTML"
                                        class="btn-secondary btn-sm"
                                        icon="fa-globe"
                                        invisible="not rips_errors_html_binary"
                                        style="text-align: left;" />

                                    <button name="action_download_rips_files"
                                        type="object"
                                        string="Descargar Archivos RIPS"
                                        class="btn-secondary btn-sm"
                                        icon="fa-download"
                                        invisible="not rips_cuv or rips_validation_status != 'validated'"
                                        style="text-align: left;" />
                                </div>
                            </group>
                        </group>

                        <!-- Configuración RIPS -->
                        <group string="Configuración RIPS" invisible="state != 'draft'">
                            <group>
                                <field name="rips_include_taxes" widget="boolean_toggle" />
                                <field name="rips_force_integer_values" widget="boolean_toggle" />
                            </group>
                            <group>
                                <button name="action_preview_rips_amounts"
                                    type="object"
                                    string="Vista Previa Montos"
                                    class="btn-info"
                                    icon="fa-eye" />
                            </group>
                        </group>

                        <!-- Validación de CUPS -->
                        <div invisible="rips_validated_cups" style="margin: 20px 0;">
                            <separator string="Validación de Códigos CUPS" />
                            <div style="text-align: center; margin: 15px 0;">
                                <button name="action_validate_cups_codes"
                                    type="object"
                                    string="Validar Códigos CUPS"
                                    class="btn-warning"
                                    icon="fa-check-circle"
                                    help="Valida que todos los productos tipo consulta/procedimiento tengan códigos CUPS válidos" />
                            </div>
                        </div>

                        <!-- Resultado validación CUPS -->
                        <div invisible="not rips_validated_cups" style="margin: 20px 0;">
                            <separator string="Resultado Validación CUPS" />
                            <div
                                style="background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 6px; padding: 12px;">
                                <i class="fa fa-check-circle"
                                    style="color: #28a745; margin-right: 8px;" />
                                <span style="color: #155724;"> Códigos CUPS validados el <field
                                        name="rips_validation_cups_date" readonly="1"
                                        class="oe_inline" />
                                </span>
                            </div>
                            <field name="rips_validation_cups_result" readonly="1" nolabel="1"
                                invisible="not rips_validation_cups_result"
                                style="margin-top: 10px;" />
                        </div>

                        <!-- Resultados de validación RIPS -->
                        <separator string="Resultados de Validación"
                            invisible="not rips_response_json or (rips_validation_status == 'validated' and not rips_errors_html)" />

                        <!-- Mensaje de éxito -->
                        <div invisible="rips_validation_status != 'validated' or rips_errors_html"
                            style="background-color: #dff0d8; border: 1px solid #d0e9c6; border-radius: 6px; padding: 16px; margin: 10px 0;">
                            <h4
                                style="color: #3c763d; margin: 0 0 8px 0; font-size: 16px; font-weight: 600;">
                                <i class="fa fa-check-circle" style="margin-right: 8px;" /> RIPS
                                Validado Exitosamente </h4>
                            <p style="color: #3c763d; margin: 0; font-size: 14px;">
                                El RIPS ha sido validado correctamente por el Ministerio de Salud y
                                se encuentra disponible para descarga.
                            </p>
                        </div>

                        <!-- Visualización de errores HTML -->
                        <div invisible="not rips_errors_html" style="margin: 16px 0;">
                            <field name="rips_errors_html" readonly="1" widget="html" nolabel="1" />
                        </div>

                        <!-- Configuración especial (modo desarrollador) -->
                        <group string="Configuración Especial"
                            invisible="move_type == 'out_invoice'" groups="base.group_no_one">
                            <group>
                                <field name="is_adjustment_note"
                                    invisible="move_type != 'out_refund'" />
                                <field name="is_voluntary_agreement"
                                    invisible="move_type != 'out_refund'" />
                                <field name="is_total_credit_note"
                                    invisible="move_type != 'out_refund'" />
                            </group>
                            <group>
                                <field name="capita_type" invisible="not capita_type" />
                                <field name="rips_without_invoice" />
                            </group>
                        </group>

                        <notebook invisible="not rips_response_json" groups="base.group_no_one">
                            <page string="Respuesta MinSalud">
                                <field name="rips_response_json" readonly="1" widget="ace"
                                    options="{'mode': 'json'}" nolabel="1" />
                            </page>
                            <page string="Histórico" invisible="not rips_consultation_history">
                                <field name="rips_consultation_history" readonly="1" widget="ace"
                                    options="{'mode': 'json'}" nolabel="1" />
                            </page>
                            <page string="JSON RIPS" invisible="not rips_json">
                                <field name="rips_json" readonly="1" widget="ace"
                                    options="{'mode': 'json'}" nolabel="1" />
                            </page>
                        </notebook>

                        <!-- Botones avanzados (modo desarrollador) -->
                        <group string="Opciones Avanzadas de Envío" groups="base.group_no_one"
                            invisible="not rips_generated" col="3">
                            <button name="action_send_fev_rips" type="object" string="Factura+RIPS"
                                class="btn-sm btn-secondary" />
                            <button name="action_send_nota_credito" type="object"
                                string="Nota Crédito" class="btn-sm btn-secondary" />
                            <button name="action_send_nota_credito_total" type="object"
                                string="NC Total" class="btn-sm btn-secondary" />
                            <button name="action_send_nota_debito" type="object"
                                string="Nota Débito" class="btn-sm btn-secondary" />
                            <button name="action_send_nota_ajuste" type="object"
                                string="Nota Ajuste" class="btn-sm btn-secondary" />
                            <button name="action_send_rips_sin_factura" type="object"
                                string="RIPS sin Factura" class="btn-sm btn-secondary" />
                            <button name="action_send_nc_acuerdo_voluntades" type="object"
                                string="NC Acuerdo" class="btn-sm btn-secondary" />
                            <button name="action_send_capita_inicial" type="object"
                                string="Cápita Inicial" class="btn-sm btn-secondary" />
                            <button name="action_send_capita_periodo" type="object"
                                string="Cápita Período" class="btn-sm btn-secondary" />
                            <button name="action_send_capita_final" type="object"
                                string="Cápita Final" class="btn-sm btn-secondary" />
                        </group>

                        <!-- Información de ayuda -->
                        <div invisible="rips_generated or rips_errors_html"
                            style="background-color: #e8f4fd; border: 1px solid #c8e1ff; border-radius: 6px; padding: 16px; margin-top: 20px;">
                            <h4
                                style="color: #0969da; margin: 0 0 8px 0; font-size: 16px; font-weight: 600;">
                                <i class="fa fa-info-circle" style="margin-right: 8px;" />
                                Información RIPS </h4>
                            <p style="color: #0969da; margin: 0; font-size: 14px;"> Para enviar el
                                RIPS al Ministerio de Salud, use el botón <strong>"Enviar RIPS al
                                MinSalud"</strong> en la parte superior. El sistema generará y
                                enviará automáticamente el archivo RIPS. </p>
                        </div>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Vista de búsqueda para facturas con campos RIPS -->
        <record id="view_account_invoice_filter_inherit_rips" model="ir.ui.view">
            <field name="name">account.move.search.inherit.rips</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter" />
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <separator />
                    <filter string="Con RIPS Generado"
                        name="with_rips"
                        domain="[('rips_generated', '=', True)]" />
                    <filter string="RIPS Validado"
                        name="rips_validated"
                        domain="[('rips_validation_status', '=', 'validated')]" />
                    <filter string="RIPS Rechazado"
                        name="rips_rejected"
                        domain="[('rips_validation_status', 'in', ['rejected', 'error'])]" />
                    <filter string="CUPS Validados"
                        name="cups_validated"
                        domain="[('rips_validated_cups', '=', True)]" />
                    <filter string="En Lote RIPS"
                        name="in_rips_export"
                        domain="[('is_in_rips_export', '=', True)]" />
                    <separator />
                    <field name="rips_cuv" string="CUV" />
                    <field name="patient_id" string="Paciente" />
                </xpath>
                <xpath expr="//group" position="inside">
                    <filter string="Estado RIPS" name="rips_status"
                        context="{'group_by': 'rips_validation_status'}" />
                    <filter string="Tipo de Carga" name="rips_load_type"
                        context="{'group_by': 'rips_last_load_type'}" />
                    <filter string="Paciente" name="patient" context="{'group_by': 'patient_id'}" />
                </xpath>
            </field>
        </record>
        <record id="view_account_move_filter_health" model="ir.ui.view">
            <field name="name">account.move.search.health</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_move_filter" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="patient_id" string="Paciente" />
                    <field name="rips_cuv" string="CUV RIPS" />
                    <field name="authorization_number" string="Número Autorización" />
                    <field name="physician_id" string="Médico" />

                    <separator />
                    <filter string="Facturas de Salud"
                        name="health_invoices"
                        domain="[('patient_id', '!=', False)]"
                        help="Facturas con paciente asignado" />

                    <filter string="Con RIPS Validado"
                        name="with_validated_rips"
                        domain="[('rips_validation_status', '=', 'validated')]"
                        help="Facturas con RIPS validado por MinSalud" />

                    <filter string="RIPS Pendiente"
                        name="rips_pending"
                        domain="[('patient_id', '!=', False), ('rips_validation_status', 'in', ['draft', 'generated'])]"
                        help="Facturas de salud sin RIPS validado" />

                    <filter string="Con Glosas"
                        name="with_glosas"
                        domain="[('has_glosa', '=', True)]"
                        help="Facturas con glosas activas" />

                    <filter string="Glosas Pendientes"
                        name="glosas_pending"
                        domain="[('glosa_state', 'in', ['glosa_pendiente', 'glosa_respondida'])]"
                        help="Facturas con glosas en proceso" />

                    <separator />
                    <filter string="Facturas Aseguradora"
                        name="insurance_invoices"
                        domain="[('invoice_type', '=', 'insurance')]" />

                    <filter string="Facturas Copago"
                        name="copay_invoices"
                        domain="[('invoice_type', '=', 'copay')]" />

                    <filter string="Operación Salud"
                        name="health_operation"
                        domain="[('fe_operation_type', 'in', ['SS-CUFE', 'SS-CUDE', 'SS-POS', 'SS-SNum', 'SS-SinAporte'])]"
                        help="Facturas con tipo de operación del sector salud" />
                </xpath>

                <xpath expr="//group" position="inside">
                    <filter string="Paciente"
                        name="group_by_patient"
                        context="{'group_by': 'patient_id'}" />

                    <filter string="Estado RIPS"
                        name="group_by_rips_status"
                        context="{'group_by': 'rips_validation_status'}" />

                    <filter string="Estado Glosa"
                        name="group_by_glosa_state"
                        context="{'group_by': 'glosa_state'}" />

                    <filter string="Tipo Factura Salud"
                        name="group_by_invoice_type"
                        context="{'group_by': 'invoice_type'}" />

                    <filter string="Médico"
                        name="group_by_physician"
                        context="{'group_by': 'physician_id'}" />
                </xpath>

            </field>
        </record>

        <!-- Vista tree con campos de salud -->
        <record id="view_move_tree_health" model="ir.ui.view">
            <field name="name">account.move.tree.health</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="patient_id" optional="show" string="Paciente" />
                </xpath>

                <xpath expr="//field[@name='state']" position="before">
                    <field name="state_dian_document"
                        string="DIAN"
                        widget="badge"
                        optional="show"
                        decoration-success="state_dian_document == 'exitoso'"
                        decoration-danger="state_dian_document in ['error', 'rechazado']"
                        decoration-info="state_dian_document in ['por_notificar','por_validar']" />

                    <field name="rips_validation_status"
                        string="RIPS"
                        widget="badge"
                        optional="show"
                        decoration-success="rips_validation_status == 'validated'"
                        decoration-danger="rips_validation_status in ['rejected', 'error']"
                        decoration-warning="rips_validation_status == 'sent'"
                        decoration-info="rips_validation_status in ['draft', 'generated']" />

                    <field name="glosa_state"
                        string="Glosa"
                        optional="show" />
                </xpath>

                <xpath expr="//field[@name='amount_total_signed']" position="after">
                    <field name="rips_cuv" optional="hide" string="CUV" />
                    <field name="glosa_total" widget="monetary" optional="hide"
                        string="Total Glosado" />
                    <field name="has_glosa" widget="boolean_toggle" optional="hide"
                        string="Tiene Glosa" />
                    <field name="invoice_type" optional="hide" string="Tipo Factura" />
                </xpath>

            </field>
        </record>
    </data>

</odoo>