    <record id="view_generar_nota_credito_wizard_form" model="ir.ui.view">
        <field name="name">generar.nota.credito.wizard.form</field>
        <field name="model">generar.nota.credito.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info mb-3" role="alert" invisible="not result">
                        <field name="result" readonly="1" class="fw-bold"/>: <field name="close_note" readonly="1" widget="html"/>
                    </div>
                    <group>
                        <group>
                            <field name="glosa_id" readonly="glosa_id"/>
                            <field name="invoice_id"/>
                            <field name="is_line_glosa" invisible="1"/>
                            <field name="invoice_line_id" invisible="not is_line_glosa"/>
                            <field name="result" invisible="1"/>
                            <field name="journal_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_factura" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="accepted_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}" class="text-danger fw-bold"/>
                        </group>
                    </group>
                    <group>
                        <field name="motivo" placeholder="Descripción detallada del motivo de la nota de crédito..."/>
                    </group>
                    <group>
                        <group>
                            <field name="generate_rips"/>
                            <field name="rips_code" invisible="not generate_rips" required="generate_rips"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_credit_note" string="Generar Nota de Crédito" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Acción para abrir el wizard -->
    <record id="action_generar_nota_credito_wizard" model="ir.actions.act_window">
        <field name="name">Generar Nota de Crédito</field>
        <field name="res_model">generar.nota.credito.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_glosa_medica"/>
        <field name="binding_view_types">form</field>
    </record>
    
