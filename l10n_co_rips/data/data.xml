        <!-- Secuencia para Glosas Médicas -->
        <record id="seq_glosa_medica" model="ir.sequence">
            <field name="name">Glosa Médica</field>
            <field name="code">glosa.medica</field>
            <field name="prefix">GLM/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Etapas predefinidas para el proceso de glosa -->
        <record id="etapa_recepcion" model="glosa.etapa">
            <field name="name">Recepción y Radicación</field>
            <field name="sequence">10</field>
            <field name="state">recepcion</field>
            <field name="fold">False</field>
            <field name="descripcion">Registro y verificación inicial de la glosa y su documentación.</field>
        </record>
        
        <record id="etapa_clasificacion" model="glosa.etapa">
            <field name="name">Clasificación y Distribución</field>
            <field name="sequence">20</field>
            <field name="state">clasificacion</field>
            <field name="fold">False</field>
            <field name="descripcion">Asignación del motivo legal y distribución a áreas correspondientes.</field>
            <field name="requiere_motivo">True</field>
        </record>
        
        <record id="etapa_revision" model="glosa.etapa">
            <field name="name">Revisión y Respuesta</field>
            <field name="sequence">30</field>
            <field name="state">revision</field>
            <field name="fold">False</field>
            <field name="descripcion">Evaluación por el equipo responsable y registro de la respuesta.</field>
            <field name="requiere_respuesta">True</field>
        </record>
        
        <record id="etapa_conciliacion" model="glosa.etapa">
            <field name="name">Conciliación</field>
            <field name="sequence">40</field>
            <field name="state">conciliacion</field>
            <field name="fold">False</field>
            <field name="descripcion">Reuniones con la entidad pagadora para resolver la glosa.</field>
        </record>
        
        <record id="etapa_rechazada" model="glosa.etapa">
            <field name="name">Glosa Rechazada</field>
            <field name="sequence">50</field>
            <field name="state">rechazado</field>
            <field name="fold">True</field>
            <field name="descripcion">Glosa rechazada totalmente (resultado favorable para la institución).</field>
            <field name="es_estado_final">True</field>
            <field name="requiere_nota_cierre">True</field>
        </record>
        
        <record id="etapa_aceptada" model="glosa.etapa">
            <field name="name">Glosa Aceptada</field>
            <field name="sequence">60</field>
            <field name="state">aceptado</field>
            <field name="fold">True</field>
            <field name="descripcion">Glosa aceptada totalmente (resultado desfavorable para la institución).</field>
            <field name="es_estado_final">True</field>
            <field name="requiere_nota_cierre">True</field>
            <field name="permite_nota_credito">True</field>
        </record>
        
        <record id="etapa_parcial" model="glosa.etapa">
            <field name="name">Glosa Parcial</field>
            <field name="sequence">70</field>
            <field name="state">parcial</field>
            <field name="fold">True</field>
            <field name="descripcion">Glosa parcialmente aceptada.</field>
            <field name="es_estado_final">True</field>
            <field name="requiere_nota_cierre">True</field>
            <field name="permite_nota_credito">True</field>
        </record>
        
        <record id="etapa_resuelta" model="glosa.etapa">
            <field name="name">Resuelto</field>
            <field name="sequence">80</field>
            <field name="state">resuelto</field>
            <field name="fold">True</field>
            <field name="descripcion">Glosa resuelta y documentación finalizada.</field>
            <field name="es_estado_final">True</field>
            <field name="requiere_nota_cierre">True</field>
            <field name="permite_nota_credito">True</field>
        </record>
        
        <record id="etapa_cancelada" model="glosa.etapa">
            <field name="name">Cancelado</field>
            <field name="sequence">100</field>
            <field name="state">cancelado</field>
            <field name="fold">True</field>
            <field name="descripcion">Glosa cancelada o anulada.</field>
            <field name="es_estado_final">True</field>
        </record>
    </data>
    <record id="action_server_export_liquidaciones_zip" model="ir.actions.server">
        <field name="name">Exportar Liquidaciones a ZIP</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_export_liquidaciones_zip()</field>
    </record>
</odoo>