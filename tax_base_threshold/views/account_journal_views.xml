<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia vista formulario account.journal para campos ICA -->
    <record id="view_account_journal_form_ica" model="ir.ui.view">
        <field name="name">account.journal.form.ica</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']" position="inside">
                <group string="Configuración ICA" name="ica_config">
                    <group>
                        <field name="use_journal_ica_city"/>
                        <field name="ica_city_id" invisible="not use_journal_ica_city"/>
                    </group>
                    <group>
                        <field name="ica_tariff_id" invisible="not use_journal_ica_city or not ica_city_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Herencia vista formulario account.move para mostrar city_id -->
    <record id="view_account_move_form_ica" model="ir.ui.view">
        <field name="name">account.move.form.ica</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="city_id" string="Municipio ICA"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')"
                       groups="account.group_account_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
