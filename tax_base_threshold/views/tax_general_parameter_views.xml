<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_general_parameter_tree" model="ir.ui.view">
        <field name="name">tax.general.parameter.tree</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <tree string="Parámetros Tributarios Generales" editable="top">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="parameter_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="value"/>
                <field name="currency_id"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_tax_general_parameter_form" model="ir.ui.view">
        <field name="name">tax.general.parameter.form</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <form string="Parámetro Tributario General">
                <sheet>
                    <widget name="web_ribbon" title="Archivado" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="parameter_type"/>
                        <h1>
                            <field name="parameter_type" placeholder="Seleccione tipo de parámetro..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="value"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tax_general_parameter_search" model="ir.ui.view">
        <field name="name">tax.general.parameter.search</field>
        <field name="model">tax.general.parameter</field>
        <field name="arch" type="xml">
            <search string="Buscar Parámetros Tributarios">
                <field name="parameter_type"/>
                <field name="date_from"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <separator/>
                <filter string="SMMLV" name="smmlv" domain="[('parameter_type', '=', 'smmlv')]"/>
                <filter string="UVT" name="uvt" domain="[('parameter_type', '=', 'uvt')]"/>
                <separator/>
                <filter string="Activo" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archivado" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Vigente" name="current" domain="[('date_from', '&lt;=', context_today()), '|', ('date_to', '&gt;=', context_today()), ('date_to', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Tipo" name="group_type" context="{'group_by': 'parameter_type'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    <filter string="Año" name="group_year" context="{'group_by': 'date_from:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tax_general_parameter" model="ir.actions.act_window">
        <field name="name">Parámetros Tributarios</field>
        <field name="res_model">tax.general.parameter</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear nuevo parámetro tributario
            </p>
            <p>
                Configure los valores de SMMLV y UVT para diferentes períodos.
                Estos valores se usarán para calcular los umbrales de base tributaria.
            </p>
        </field>
    </record>
</odoo>
