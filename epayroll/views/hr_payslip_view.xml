<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payslip_edi_tree" model="ir.ui.view">
        <field name="name">hr.payslip.edi.tree</field>
        <field name="model">hr.payslip.edi</field>
        <field name="arch" type="xml">
            <tree string="Payslips" js_class="hr_payroll_payslip_tree" sample="1">
                <field name="company_id" column_invisible="1"/>
                <field name="currency_id" column_invisible="1" />
                <field name="number" decoration-bf="1" />
                <field name="employee_id" widget="many2one_avatar_employee" />
                <field name="payslip_run_id" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="company_id" 
                    options="{'no_create': True}" />
                <field name="basic_wage" widget="monetary"
                    options="{'currency_field': 'currency_id'}" />
                <field name="net_wage" widget="monetary"
                    options="{'currency_field': 'currency_id'}" />
                <field name="total_devengos" widget="monetary"
                    options="{'currency_field': 'currency_id'}" />
                <field name="total_deducciones" widget="monetary" options="{'currency_field': 'currency_id'}"
                    decoration-bf="1" />
                <field name="total_paid" widget="monetary" options="{'currency_field': 'currency_id'}"
                    decoration-bf="1" />
                <field name="matched_payslips" />
                <field name="state" widget="badge" decoration-info="state == 'draft'"
                    decoration-warning="state == 'verify'"
                    decoration-success="state in ('done','paid')" />
            </tree>
        </field>
    </record>
    <record id="view_hr_payslip_edi_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.form</field>
        <field name="model">hr.payslip.edi</field>
        <field name="arch" type="xml">
            <form string="Payslip Edi">
                <header>
                    <button string="Confirm" name="update_data" type="object" />
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <div class="oe_title">
                        <label for="employee_id" class="oe_edit_only" />
                        <h1>
                            <field name="employee_id" placeholder="Employee" />
                        </h1>
                    </div>
                    <group col="4">
                        <field name="company_id" invisible="1"/>
                        <label for="date_from" string="Period" />
                        <div>
                            <field name="date_from" class="oe_inline" /> - <field name="date_to"
                                class="oe_inline" />
                        </div>
                        <field name="contract_id"
                            domain="[('employee_id','=',employee_id),('date_start','&lt;=',date_to),'|',('date_end','&gt;=',date_from),('date_end','=',False)]"
                            context="{'default_employee_id': employee_id}" required="1" />
                        <field name="number" />
                        <field name="struct_id" required="1" />
                        <field name="wage_type" invisible="1" />
                        <field name="name" />
                        <field name="sum_worked_hours" invisible="1" />
                        <field name="total_devengos" readonly="1" />
                        <field name="total_deducciones" readonly="1" />
                        <field name="total_paid" readonly="1" />
                        <field name="matched_payslips" readonly="1"/>
                        <field name="normal_wage" invisible="1" />
                        <field name="credit_note" invisible="1" />
                        <field name="is_superuser" invisible="1" />
                        <field name="validar_cron" />
                    </group>
                    <notebook>
                        <page name="nomina_relacionadas" string="Nomina Relacionadas">
                            <field name="payslip_ids">
                                <tree string="Nomina Relacionadas" editable="bottom">
                                    <field name="currency_id" column_invisible="1" />
                                    <field name="number" decoration-bf="1" />
                                    <field name="employee_id" widget="many2one_avatar_employee" />
                                    <field name="date_from" />
                                    <field name="date_to" />
                                    <field name="company_id" 
                                        options="{'no_create': True}" />
                                    <field name="basic_wage" widget="monetary"
                                        options="{'currency_field': 'currency_id'}" />
                                    <field name="net_wage" widget="monetary"
                                        options="{'currency_field': 'currency_id'}"
                                        decoration-bf="1" />
                                    <field name="state" widget="badge"
                                        decoration-info="state == 'draft'"
                                        decoration-warning="state == 'verify'"
                                        decoration-success="state in ('done','paid')" />
                                </tree>
                            </field>
                        </page>
                        <page string="Worked Days &amp; Inputs" name="worked_days_input">
                            <separator string="Worked Days" />
                            <field name="worked_days_line_ids">
                                <tree string="Worked Days" editable="bottom" create="0" delete="0">
                                    <field name="work_entry_type_id" readonly="1" force_save="1" />
                                    <field name="name" />
                                    <field name="number_of_days" sum="Total Working Days"
                                        readonly="1" force_save="1" />
                                    <field name="number_of_hours" readonly="1" force_save="1" />
                                    <field name="amount" readonly="1" sum="Total Amount"
                                        force_save="1" />
                                    <field name="is_paid" column_invisible="True" readonly="1"
                                        force_save="1" />
                                    <field name="sequence" column_invisible="True" readonly="1"
                                        force_save="1" />
                                </tree>
                                <form string="Worked Day">
                                    <group col="4">
                                        <field name="work_entry_type_id" />
                                        <field name="name" />
                                        <field name="sequence" />
                                        <field name="number_of_days" />
                                        <field name="number_of_hours" />
                                        <field name="amount" />
                                        <field name="is_paid" />
                                        <field name="contract_id" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Salary Computation" name="salary_computation">
                            <field name="line_ids" colspan="4" nolabel="1">
                                <tree string="Salary Structure" editable="bottom"
                                    decoration-info="total == 0" create="0" delete="0">
                                    <field name="name" />
                                    <field name="code" readonly="1" force_save="1" />
                                    <field name="leave_id" />
                                    <field name="initial_accrual_date" />
                                    <field name="final_accrual_date" />
                                    <field name="category_id" readonly="1" force_save="1" />
                                    <field name="sequence" column_invisible="1" readonly="1" force_save="1" />
                                    <field name="quantity" readonly="1" force_save="1" />
                                    <field name="rate" readonly="1" force_save="1" />
                                    <field name="salary_rule_id" groups="base.group_no_one"
                                        readonly="1" force_save="1" />
                                    <field name="amount" readonly="1" force_save="1" />
                                    <field name="total" readonly="1" force_save="1" />
                                </tree>
                                <form string="Payslip Line">
                                    <group col="4">
                                        <field name="name" />
                                        <field name="code" />
                                        <field name="category_id" />
                                        <field name="leave_id" />
                                        <field name="sequence" />
                                        <field name="quantity" />
                                        <field name="rate" />
                                        <field name="amount" />
                                        <field name="total" />
                                        <field name="salary_rule_id" />
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Accounting Information" name="account_info">
                            <group>
                                <group string="Miscellaneous">
                                    <field name="company_id"  options="{'no_create': True}" />
                                    <field name="payslip_run_id"
                                        domain="[('state','in',('draft', 'verify'))]" />
                                </group>
                                <group name="accounting" string="Accounting">
                                    <field name="paid" readonly="1" />
                                </group>
                            </group>
                            <div colspan="4">
                                <field name="note" placeholder="Add an internal note..." />
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>
    <record id="action_view_hr_payslip_edi_month_form" model="ir.actions.act_window">
        <field name="name">Nomina Electronica por empleado</field>
        <field name="res_model">hr.payslip.edi</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{"search_default_group_by_batch":1}</field>
    </record>

    <menuitem
        id="menu_hr_payroll_employee_edi_payslips"
        name="Nomina Electronica por empleado"
        parent="hr_payroll.menu_hr_payroll_payslips"
        sequence="60"
        action="action_view_hr_payslip_edi_month_form"
        groups="hr_payroll.group_hr_payroll_user" />

    <record id="hr_payslip_run_tree" model="ir.ui.view">
        <field name="name">hr.payslip.run.tree</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <tree string="Payslips Batches" sample="1">
                <field name="name" />
                <field name="date_start" />
                <field name="date_end" />
                <field name="state" />
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <record id="hr_payslip_edi_run_form" model="ir.ui.view">
        <field name="name">hr.payslip.edi.run.form</field>
        <field name="model">hr.payslip.edi.run</field>
        <field name="arch" type="xml">
            <form string="Payslips Batches">
            <header>
                <button name="%(action_hr_payslip_by_edi_employees)d" type="action" invisible="state != 'draft'"
                    string="Generate Payslips" class="oe_highlight" />
                <button name="action_validate" type="object" string="Validate" invisible="state != 'verify'"
                    class="oe_highlight" context="{'payslip_generate_pdf': True}" />
                <button name="restart_full_payroll_batch" type="object" string="Reiniciar Lote" invisible="state != 'verify'"
                    class="oe_highlight"  />
                <button name="action_confirm" type="object" string="Enviar Dian" invisible="state != 'verify'" class="oe_highlight" context="{'payslip_generate_pdf': True}"/>
                <button name="compute_sheet" type="object" string="Computar Lote" invisible="state != 'verify'" class="oe_highlight"/>
                <button name="action_retry_errors" type="object" string="Reintentar Errores con Fallo" 
                    class="oe_highlight" invisible="not has_errors"/>
                <button string="Set to Draft" name="action_draft" type="object" invisible="state != 'close'"/>
                <field name="state" widget="statusbar" />
            </header>
                <sheet>
                    <field  name="has_errors" />
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_payslips" class="oe_stat_button" icon="fa-book"
                            type="object" help="Generated Payslips"
                            invisible="payslip_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="payslip_count" />
                                </span>
                                <span class="o_stat_text">Nomina E</span>
                            </div>
                        </button>
                        <button name="action_view_errors" type="object" 
                            class="oe_stat_button" icon="fa-exclamation-triangle"
                            invisible="error_count == 0">
                            <field name="error_count" widget="statinfo" string="Errores"/>
                        </button>
                    </div>
                    <label for="name" class="oe_edit_only" />
                    <h1>
                        <field name="name" />
                    </h1>
                    <group>
                        <group>
                            <label for="date_start" string="Period" />
                            <div class="o_row">
                                <field name="date_start" class="oe_inline" /> - <field
                                    name="date_end" class="oe_inline" />
                            </div>
                        </group>
                        <group>
                            <field name="credit_note" />
                            <field name="company_id" invisible="1"/>
                            <field name="company_id"  />
                        </group>
                    </group>
                    <notebook>
                        <page name="nomina_relacionadas" string="Nomina Relacionadas">
                            <field name="slip_ids"/>
                        </page>
                        <page name="error_logs" string="Registro de Errores" invisible="error_count == 0">
                            <field name="error_log_ids" readonly="1">
                                <tree>
                                    <field name="create_date"/>
                                    <field name="payslip_id"/>
                                    <field name="error_message"/>
                                    <field name="state"/>
                                    <field name="resolved_date"/>
                                    <button name="action_retry" string="Reintentar" type="object" 
                                        icon="fa-refresh" invisible="state == 'resolved'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_payslip_edi_run_tree" model="ir.actions.act_window">
        <field name="name">Nomina Electronica Masiva</field>
        <field name="res_model">hr.payslip.edi.run</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="menu_hr_payroll_employee_edi_payslips_run"
        name="Nomina Electronica Masiva"
        parent="hr_payroll.menu_hr_payroll_payslips"
        sequence="60"
        action="action_hr_payslip_edi_run_tree"
        groups="hr_payroll.group_hr_payroll_user" />

</odoo>